              "content": "=You are a technology news analyst.\n\nReturn ONLY raw JSON with no markdown, no asterisks, no code blocks, no formatting symbols.\n\n{\n  \"summary\": \"\",\n  \"categories\": [],\n  \"primary_category\": \"\",\n  \"relevance_score\": 0,\n  \"sentiment\": \"\",\n  \"business_impact\": \"\",\n  \"key_companies\": [],\n  \"key_technologies\": [],\n  \"article_type\": \"\"\n}\n\nTitle:\n{{ $json.title }}\n\nContent:\n{{ $json.raw_content }}\n\nSource:\n{{ $json.source_name }}"
            }
