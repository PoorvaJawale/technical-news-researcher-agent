    {
      "parameters": {
        "jsCode": "let response =\n$input.first().json.output[0].content[0].text;\n\n// Remove markdown code fences\nresponse = response\n  .replace(/```json/g, '')\n  .replace(/```/g, '')\n  .trim();\n\nconst jsonMatch =\nresponse.match(/\\{[\\s\\S]*\\}/);\n\nif (!jsonMatch) {\n  throw new Error(\"No JSON found\");\n}\n\nconst parsed =\nJSON.parse(jsonMatch[0]);\n\nif (!$('Loop Over Items').item.json.id) {\n  throw new Error('raw_article_id missing');\n}\n\nreturn [{\n  json: {\n    raw_article_id: $('Loop Over Items').item.json.id,\n\n    title: $('Loop Over Items').item.json.title,\n\n    source_name: $('Loop Over Items').item.json.source_name,\n\n    summary: parsed.summary,\n\n    primary_category: parsed.primary_category,\n\n    relevance_score: parsed.relevance_score,\n\n    sentiment: parsed.sentiment,\n\n    business_impact: parsed.business_impact,\n\n    key_technologies: parsed.key_technologies,\n\n    categories: parsed.categories,\n\nkey_companies: parsed.key_companies,\n\narticle_type: parsed.article_type\n  }\n}];"
      },
